                  }
                ],
                "is_impossible": false
              }
            ]
          },
          {
            "context": "Whoever causes any circumstance to exist or makes any false entry in any book or record, or electronic record or makes any document or electronic record containing a false statement, intending that such circumstance, false entry or false statement may appear in evidence in a judicial proceeding, or in a proceeding taken by law before a public servant as such, or before an arbitrator, and that such circumstance, false entry or false statement, so appearing in evidence, may cause any person who in such proceeding is to form an opinion upon the evidence, to entertain an erroneous opinion touching any point material to the result of such proceeding is said “to fabricate false evidence”.",
            "qas": [
              {
                "question": "What is the definition of fabricating false evidence?",
                "id": "q23",
                "answers": [
                  {
                    "text": "Causing any circumstance to exist or making any false entry in any book, record, or electronic record, or making any document or electronic record containing a false statement, intending that it may appear in evidence and cause an erroneous opinion in a judicial proceeding.",
                    "answer_start": 8
                  }
                ],
                "is_impossible": false
              },
              {
                "question": "Can false entries in electronic records be considered as fabricating false evidence?",
                "id": "q24",
