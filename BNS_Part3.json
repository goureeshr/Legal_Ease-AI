          "qas": [
            {
              "question": "What is the punishment for the first conviction under Section 295?",
              "id": "q119",
              "answers": [
                {
                  "text": "Imprisonment of either description for a term which may extend to three years, and with fine which may extend to two thousand rupees.",
                  "answer_start": 223
                }
              ],
              "is_impossible": false
            },
            {
              "question": "What is the punishment for subsequent convictions under Section 295?",
              "id": "q120",
              "answers": [
