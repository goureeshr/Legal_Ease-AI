                ],
                "is_impossible": false
              }
            ]
          },
          {
            "context": "Whoever malignantly does any act which is, and which he knows or has reason to believe to be, likely to spread the infection of any disease dangerous to life, shall be punished with imprisonment of either description for a term which may extend to two years, or with fine, or with both.",
            "qas": [
